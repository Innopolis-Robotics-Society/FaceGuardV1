# Server
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8081
API_KEY=change-me-agent-key
DEVICE_ID=faceguard-pi-001
DEVICE_NAME=Front Door FaceGuard

# Camera
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=15
CAMERA_ALLOW_SIMULATION=true

# OpenCV LBPH
RECOGNITION_ENABLED=true
RECOGNITION_THRESHOLD=65
RECOGNITION_INTERVAL_SECONDS=0.25
RECOGNITION_COOLDOWN_SECONDS=5
UNKNOWN_COOLDOWN_SECONDS=10
MIN_FACE_SIZE=80

# Hardware: auto | mock | raspberry_pi
HARDWARE_MODE=auto
SERVO_GPIO_PIN=17
SERVO_OPEN_VALUE=0.8
SERVO_CLOSED_VALUE=-0.8
DOOR_OPEN_SECONDS=2

# Keep false on Windows and during development.
# On Raspberry Pi set true only after sudo/systemd permissions are configured.
SYSTEM_COMMANDS_ENABLED=false
AGENT_SERVICE_NAME=faceguard-agent

# Optional central FastAPI server. Leave empty for fully offline standalone mode.
CENTRAL_SERVER_URL=
CENTRAL_DEVICE_TOKEN=
HEARTBEAT_INTERVAL_SECONDS=10

LOG_LEVEL=INFO
