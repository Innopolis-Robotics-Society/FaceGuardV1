# ========================================
# FaceGuard Frontend Docker Configuration
# ========================================

# Backend API URL
# Локальный backend (если запущен на хосте)
VITE_API_URL=http://localhost:8000/api/v1

# WebSocket URL
VITE_WS_URL=ws://localhost:8000

# ========================================
# Примеры для разных конфигураций:
# ========================================

# Удаленный сервер:
# VITE_API_URL=http://192.168.1.100:8000/api/v1
# VITE_WS_URL=ws://192.168.1.100:8000

# Production с SSL:
# VITE_API_URL=https://api.faceguard.com/api/v1
# VITE_WS_URL=wss://api.faceguard.com

# Университетская сеть:
# VITE_API_URL=http://10.93.26.183:8000/api/v1
# VITE_WS_URL=ws://10.93.26.183:8000
