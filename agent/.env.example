# Backend connection
BACKEND_URL=http://backend:8000
DEVICE_ID=
DEVICE_CODE=rpi-main-001

# Hardware mode: development or raspberry_pi
HARDWARE_MODE=development

# Camera settings
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Recognition settings (lower threshold = stricter)
RECOGNITION_THRESHOLD=70
MIN_FACE_SIZE=80
FACE_SCALE_FACTOR=1.2
FACE_MIN_NEIGHBORS=5

# Door control
SERVO_GPIO_PIN=17
DOOR_OPEN_DURATION=5
ACTION_COOLDOWN_SECONDS=5

# Sync intervals (seconds)
HEARTBEAT_INTERVAL=10
TELEMETRY_INTERVAL=30
SYNC_INTERVAL=60
COMMAND_POLL_INTERVAL=5

# Logging
LOG_LEVEL=INFO
