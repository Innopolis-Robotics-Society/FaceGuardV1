# Backend connection
BACKEND_URL=http://localhost:8000
DEVICE_ID=
DEVICE_CODE=rpi-main-001


# Hardware mode - development uses OpenCV for webcam
HARDWARE_MODE=development

# Camera settings - for webcam
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=60

# Recognition settings
# RECOGNITION_MODEL: lbph (default, fast) or deepface (more accurate)
RECOGNITION_MODEL=lbph

# DeepFace model options (only used when RECOGNITION_MODEL=deepface):
# VGG-Face, Facenet, Facenet512, OpenFace, DeepFace, DeepID, ArcFace, Dlib
DEEPFACE_MODEL=Facenet

# Distance metric for DeepFace: cosine, euclidean, euclidean_l2
DEEPFACE_DISTANCE_METRIC=cosine

# Recognition threshold (for LBPH: lower is stricter, typically 50-100)
RECOGNITION_THRESHOLD=70

# Liveness detection (basic anti-spoofing: blink, motion, texture)
# Prevents recognition via photo/video
LIVENESS_ENABLED=false
LIVENESS_BLINK_REQUIRED=true
LIVENESS_MOTION_REQUIRED=false
LIVENESS_TIMEOUT_SECONDS=3

# MiniFASNet Anti-Spoofing (advanced CNN-based detection)
# Detects printed photos, digital photos (phone screen), video replay attacks
# NOTE: Requires model file to be downloaded first (see ANTISPOOFING_SETUP.md)
ANTISPOOFING_ENABLED=false
ANTISPOOFING_THRESHOLD=0.5
ANTISPOOFING_MODEL_PATH=data/models/antispoofing/minifasnet_v2.pth
ANTISPOOFING_DEVICE=cpu

MIN_FACE_SIZE=80
FACE_SCALE_FACTOR=1.2
FACE_MIN_NEIGHBORS=5

# MIN_FACE_SIZE=60
# FACE_SCALE_FACTOR=1.1
# FACE_MIN_NEIGHBORS=3

# Door control (mock on development)
SERVO_GPIO_PIN=17
DOOR_OPEN_DURATION=5
ACTION_COOLDOWN_SECONDS=5

# LED indicator (RGB LED for visual feedback)
# Red: access denied, Green: access granted (>=60%), Blue: low confidence (<60%)
LED_RED_PIN=17
LED_GREEN_PIN=27
LED_BLUE_PIN=22
LED_DURATION=2.0

# Sync settings
HEARTBEAT_INTERVAL=10
TELEMETRY_INTERVAL=30
SYNC_INTERVAL=60
COMMAND_POLL_INTERVAL=5

# Stream server
STREAM_PORT=8001

# Logging
LOG_LEVEL=INFO
