# Backend connection - используйте IP адрес вашего сервера
# Если backend на том же Raspberry Pi: http://localhost:8000
# Если backend на другом компьютере: http://192.168.1.100:8000
BACKEND_URL=http://192.168.1.100:8000

# Device settings - получите из backend после регистрации
DEVICE_ID=
DEVICE_CODE=rpi-main-001

# Hardware mode - raspberry_pi для реального железа
HARDWARE_MODE=raspberry_pi

# Camera settings - для Raspberry Pi Camera Module v2/v3
# Для USB камеры используйте CAMERA_INDEX=0
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# Recognition settings
RECOGNITION_MODEL=lbph
RECOGNITION_THRESHOLD=70
MIN_FACE_SIZE=60
FACE_SCALE_FACTOR=1.1
FACE_MIN_NEIGHBORS=3

# GPIO settings для сервопривода двери
SERVO_GPIO_PIN=17
DOOR_OPEN_DURATION=5
ACTION_COOLDOWN_SECONDS=5

# Sync settings
HEARTBEAT_INTERVAL=10
TELEMETRY_INTERVAL=30
SYNC_INTERVAL=60
COMMAND_POLL_INTERVAL=5

# Stream server - порт для видеопотока
STREAM_PORT=8001

# Liveness detection (basic anti-spoofing: blink, motion, texture)
LIVENESS_ENABLED=true
LIVENESS_BLINK_REQUIRED=false
LIVENESS_MOTION_REQUIRED=false
LIVENESS_TIMEOUT_SECONDS=3

# MiniFASNet Anti-Spoofing (advanced CNN-based detection)
# NOTE: Requires model file to be downloaded first
ANTISPOOFING_ENABLED=true
ANTISPOOFING_THRESHOLD=0.5
ANTISPOOFING_MODEL_PATH=data/models/antispoofing/minifasnet_v2.pth
ANTISPOOFING_DEVICE=cpu

# Logging
LOG_LEVEL=INFO
