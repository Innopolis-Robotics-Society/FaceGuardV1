# Application
ENVIRONMENT=development
APP_NAME=FaceGuard Backend
APP_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Database
DATABASE_URL=postgresql://faceguard:faceguard@postgres:5432/faceguard
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Security
SECRET_KEY=change-this-secret-key-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Storage
DATA_DIR=/data
FACES_DIR=/data/faces
EVENTS_DIR=/data/events
VIDEOS_DIR=/data/videos
THUMBNAILS_DIR=/data/thumbnails
RECOGNITION_DIR=/data/recognition
LOGS_DIR=/data/logs
BACKUPS_DIR=/data/backups
TEMP_DIR=/data/temporary
TRASH_DIR=/data/trash

# File Limits
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png
ALLOWED_VIDEO_EXTENSIONS=mp4,avi,mkv

# Telemetry
TELEMETRY_RETENTION_DAYS=7
TELEMETRY_AGGREGATION_ENABLED=true

# Audit
AUDIT_LOG_RETENTION_DAYS=365

# Backups
BACKUP_RETENTION_DAYS=30
BACKUP_AUTO_CLEANUP=true

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_TIMEOUT=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
